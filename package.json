{
  "name": "diana-mile",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:www": "npm run dev -w apps/www",
    "dev:linktree": "npm run dev -w apps/linktree",
    "dev:shop": "npm run dev -w apps/shop",
    "dev:admin": "npm run dev -w apps/admin",
